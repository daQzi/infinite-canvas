{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "无限画布",
  "version": "0.6.2",
  "identifier": "best.canvas.infinite.tauri",
  "build": {
    "beforeDevCommand": "cd ../web && bun run dev",
    "beforeBuildCommand": "cd ../web && bun run build:tauri",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "无限画布",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "appimage", "deb"],
    "category": "GraphicsAndDesign",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "无限画布创作工具",
    "longDescription": "无限画布是一款面向图片创作的开源工作台。"
  }
}
